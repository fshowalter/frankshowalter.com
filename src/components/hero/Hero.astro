---
import type { ComponentProps } from "astro/types";

import PagefindSearch from "~/components/pagefind-search/PagefindSearch.astro";

import Backdrop from "./Backdrop.astro";
import Deck from "./Deck.astro";
import Title from "./Title.astro";

export type Props = {
  backdropImageProps?: BackdropProps["backdropImageProps"];
  centerText: boolean;
  deckProps: ComponentProps<typeof Deck>;
  titleProps: ComponentProps<typeof Title>;
};

type BackdropProps = ComponentProps<typeof Backdrop>;

const { backdropImageProps, centerText, deckProps, titleProps } = Astro.props;
---

<Backdrop backdropImageProps={backdropImageProps} centerText={centerText}>
  <Title {...titleProps} />
  <Deck center={centerText} {...deckProps} />
  <PagefindSearch />
</Backdrop>
