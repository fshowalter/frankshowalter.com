---
import type { BackdropImageProps } from "~/assets/backdrops";

import { BackdropImageConfig } from "./BackdropImageConfig";

export type Props = {
  backdropImageProps: BackdropImageProps | undefined;
  centerText: boolean;
  children: any;
};

const { backdropImageProps, centerText, children } = Astro.props;
---

<header
  class={`
    relative flex max-h-[1350px] min-h-[90vh] w-full flex-col content-start
    items-center justify-end
    ${backdropImageProps ? "bg-[#2A2B2A] text-white" : "text-default"}
    pt-40 pb-20
    tablet:pt-40 tablet:pb-20
    laptop:pt-60 laptop:pb-30
  `}
>
  {
    backdropImageProps && (
      <img
        class="absolute inset-0 size-full object-cover object-bottom"
        {...backdropImageProps}
        {...BackdropImageConfig}
        alt=""
        fetch-priority="high"
        loading="eager"
      />
    )
  }
  <div
    class={`
      ${centerText ? "items-center" : ""}
      z-10 mx-auto flex w-full max-w-(--breakpoint-desktop) flex-col
      px-container
      ${
        backdropImageProps
          ? `
            after:absolute after:top-0 after:left-0 after:-z-10 after:size-full
            after:bg-(image:--hero-gradient)
          `
          : ""
      }
    `}
  >
    {children}
  </div>
</header>
