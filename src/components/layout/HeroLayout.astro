---
import "~/css/tailwind.css";
import type { ComponentProps } from "astro/types";

import Footer from "./Footer.astro";
import Head from "./Head.astro";
import Hero from "./Hero.astro";
import Logo from "./Logo.astro";

export type Props = {
  headProps: ComponentProps<typeof Head>;
  heroProps: ComponentProps<typeof Hero>;
  logo: boolean;
  mainProps?:
    | undefined
    | {
        classNames: string;
      };
};

const { headProps, heroProps, logo = false, mainProps } = Astro.props;
---

<!doctype html>
<html class="h-full scroll-smooth" lang="en">
  <Head {...headProps} />
  <body class="h-full">
    <div class="h-full">
      <div class="flex min-h-full w-full flex-col bg-default">
        {
          logo && (
            <div
              class={`absolute top-0 left-0 z-nav px-container py-6 text-white`}
            >
              <Logo />
            </div>
          )
        }
        <main
          class:list={[`z-above grow bg-subtle`, mainProps?.classNames]}
          id="content"
        >
          <Hero {...heroProps} centerText={true}>{heroProps.deck}</Hero>
          <slot />
        </main>
        <Footer />
      </div>
    </div>
  </body>
</html>
