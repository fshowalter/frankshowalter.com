---
import type { HTMLAttributes } from "astro/types";

import type { StillImageProps } from "~/assets/stills";

export type Props = HTMLAttributes<"img"> & {
  classNames?: string;
  decoding: "async" | "auto" | "sync";
  height: number;
  imageProps: StillImageProps;
  loading: "eager" | "lazy";
  sizes: string;
  width: number;
};

const { classNames, imageProps, ...rest } = Astro.props;
---

<img
  {...imageProps}
  alt=""
  class:list={[`aspect-video`, classNames]}
  {...rest}
/>
