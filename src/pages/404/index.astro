---
import { getHeroBackdropImageProps } from "~/components/hero/getHeroBackdropImageProps";
import Layout from "~/components/layout/Layout.astro";

const title = "404 Not Found";
const deck = `"It's hard for us here to be reporting this to you, but it does seem to be a fact."`;
const backdropImageProps = await getHeroBackdropImageProps("not-found");
---

<Layout
  headProps={{
    canonical: false,
    meta: { description: deck },
    openGraph: false,
    title: title,
  }}
  heroProps={{
    backdropImageProps,
    centerText: true,
    deckProps: {
      value: deck,
    },
    titleProps: {
      value: title,
    },
  }}
  logo={true}
  mainProps={{
    classNames: "flex flex-col bg-subtle",
  }}
/>
