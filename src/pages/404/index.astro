---
import HeroLayout from "~/components/layout/HeroLayout.astro";

const title = "404 Not Found";
const deck = `"It's hard for us here to be reporting this to you, but it does seem to be a fact."`;
---

<HeroLayout
  headProps={{
    canonical: false,
    meta: { description: deck },
    openGraph: false,
    title: title,
  }}
  heroProps={{
    backdropSlug: "not-found",
    deck,
    title,
  }}
  logo={true}
/>
