---
import type { MovielogData } from "~/schemas";

import { getStillImageProps } from "~/assets/stills";
import Grade from "~/components/grade/Grade.astro";
import Still from "~/components/still/Still.astro";
import { toDisplayDate } from "~/utils/toDisplayDate";

export type Props = {
  classNames?: string;
  element?: "div" | "li";
  imageConfig: {
    height: number;
    sizes: string;
    width: number;
  };
  value: MovielogData;
  variant?: "default" | "splash";
};

const { classNames, element = "li", imageConfig, value, variant } = Astro.props;

const Element = element;

const stillImageProps = await getStillImageProps(value.slug, imageConfig);
---

<Element
  class:list={[
    `
      group/card relative mb-1 flex w-(--review-card-width) transform-gpu
      flex-col bg-default px-[8%] pt-12 transition-transform duration-500
      tablet:mb-0 tablet:px-0 tablet:pt-0
      tablet-landscape:has-[a:hover]:-translate-y-2
      tablet-landscape:has-[a:hover]:drop-shadow-2xl
    `,
    classNames,
  ]}
>
  <div
    class={`
      relative mb-6 block overflow-hidden
      after:absolute after:top-0 after:left-0 after:aspect-video after:size-full
      after:bg-default after:opacity-15 after:duration-500
      group-has-[a:hover]/card:after:opacity-0
      tablet:after:inset-x-0 tablet:after:top-0
    `}
  >
    <Still
      classNames={`
        h-auto w-full transform-gpu transition-transform duration-500
        group-has-[a:hover]/card:scale-110
      `}
      decoding="async"
      fetchpriority={variant === "splash" ? "high" : "auto"}
      imageProps={stillImageProps}
      loading={variant === "splash" ? "eager" : "lazy"}
      {...imageConfig}
    />
  </div>
  <div
    class={`
      flex grow flex-col px-1 pb-8
      ${
        variant === "splash"
          ? `
            tablet:px-[4%]
            laptop:pr-[5%] laptop:pl-[4.25%]
          `
          : `
            tablet:px-[8%]
            laptop:pr-[10%] laptop:pl-[8.5%]
          `
      }
    `}
  >
    <div
      class={`
        mb-2 font-sans text-xs/4 font-normal tracking-wider text-subtle
        uppercase
        laptop:tracking-wide
      `}
    >
      {toDisplayDate(value.date)}
    </div>
    <a
      class={`
        z-[calc(var(--z-index-above)+1)] mb-2 font-sans text-xs tracking-wide
        text-accent uppercase
      `}
      href="https://www.franksmovielog.com/"
    >
      Movie Reviews
    </a>
    <a
      class={`
        mb-3 block text-2xl/7 font-medium text-default transition-all
        duration-500
        after:absolute after:top-0 after:left-0 after:z-above after:size-full
        tablet:text-2.5xl
        ${variant === "splash" ? "laptop:text-3xl" : "laptop:text-2.5xl"}
        hover:text-accent
        tablet:text-2xl
      `}
      href={`https://www.franksmovielog.com/reviews/${value.slug}/`}
    >
      {value.title}<span class="text-sm leading-none font-normal text-muted">
        &nbsp;{value.year}
      </span>
    </a>

    <Grade
      classNames={`
        mb-5
        ${variant === "splash" ? `tablet:mb-8` : `tablet:mb-6`}
      `}
      height={variant === "splash" ? 24 : 18}
      value={value.stars}
    />

    <div
      class:list={[
        `mb-6 tracking-prose text-muted`,
        { "text-lg": variant === "splash" },
      ]}
      set:html={value.excerpt}
    />
    <div
      class={`
        mt-auto font-sans text-xs/4 tracking-wider text-subtle
        laptop:tracking-wide
      `}
    >
      {
        value.genres.map((genre, index) => {
          if (index === 0) {
            return genre;
          }

          return `, ${genre}`;
        })
      }
    </div>
  </div>
</Element>
