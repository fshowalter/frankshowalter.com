---
import type { BooklogUpdateCardValue } from "~/components/booklog-update-card/BooklogUpdateCard.astro";
import type { MovielogUpdateCardValue } from "~/components/movielog-update-card/MovielogUpdateCard.astro";

import BooklogUpdateCard from "~/components/booklog-update-card/BooklogUpdateCard.astro";
import MovielogUpdateCard from "~/components/movielog-update-card/MovielogUpdateCard.astro";
import UpdateListHeading from "~/components/update-list-heading/UpdateListHeading.astro";

import { CoverImageConfig } from "./CoverImageConfig";
import { StillDefaultImageConfig } from "./StillDefaultImageConfig";
import { StillSplashImageConfig } from "./StillSplashImageConfig";

export type Props = {
  booklogUpdates: BooklogUpdateCardValue[];
  movielogUpdates: MovielogUpdateCardValue[];
};

const { booklogUpdates, movielogUpdates } = Astro.props;
---

<div class="w-full bg-subtle pb-16">
  <div
    class={`
      mx-auto w-full max-w-[1056px] gap-x-16
      tablet:px-container
      laptop:flex laptop:max-w-(--breakpoint-desktop)
    `}
  >
    <nav
      class={`
        w-full max-w-[1056px]
        desktop:grow
      `}
    >
      <UpdateListHeading
        accentText="Movie Reviews"
        href="https://www.franksmovielog.com"
        text="Latest"
      />
      <ol
        class={`
          flex flex-wrap justify-between gap-x-[2%]
          tablet:gap-y-[3vw]
          laptop:gap-y-[3vw]
        `}
      >
        {
          movielogUpdates.slice(0, 5).map((value, index) => {
            return (
              <MovielogUpdateCard
                classNames={`
                  ${
                    index === 0
                      ? `[--review-card-width:100%]`
                      : `tablet:[--review-card-width:48%]`
                  }
                `}
                element="li"
                imageConfig={
                  index === 0 ? StillSplashImageConfig : StillDefaultImageConfig
                }
                value={value}
                variant={index === 0 ? "splash" : "default"}
              />
            );
          })
        }
      </ol>
      <div
        class={`
          flex px-container py-10
          has-[a:hover]:drop-shadow-lg
        `}
      >
        <a
          class={`
            group/all-reviews mx-auto w-full max-w-[500px] transform-gpu
            rounded-md bg-default pt-5 pb-4 text-center font-sans text-base
            font-medium text-accent transition-all duration-500
            hover:scale-105 hover:bg-accent hover:text-white
          `}
          href="https://www.franksmovielog.com/reviews/"
        >
          <span
            class={`
              relative inline-block pb-1
              after:absolute after:bottom-0 after:left-0 after:h-px after:w-full
              after:origin-center after:scale-x-0 after:transform-gpu
              after:bg-white after:transition-transform after:duration-500
              group-hover/all-reviews:after:scale-x-100
            `}
          >
            More Movie Reviews
          </span>
        </a>
      </div>
    </nav>
    <nav
      class={`
        mx-auto w-full max-w-[720px]
        laptop:min-w-[548px]
        desktop:shrink
      `}
    >
      <UpdateListHeading
        accentText="Book Reviews"
        href="https://www.franksbooklog.com"
        text="Latest"
      />
      <ol class="flex flex-col gap-y-[2vw]" data-testid="booklog-updates">
        {
          booklogUpdates.slice(0, 5).map((value) => {
            return (
              <BooklogUpdateCard
                element="li"
                imageSizes={CoverImageConfig.sizes}
                value={value}
              />
            );
          })
        }
      </ol>
      <div
        class={`
          flex px-container py-10
          has-[a:hover]:drop-shadow-lg
        `}
      >
        <a
          class={`
            group/all-reviews mx-auto w-full max-w-[500px] transform-gpu
            rounded-md bg-default pt-5 pb-4 text-center font-sans text-base
            font-medium text-accent transition-all duration-500
            hover:scale-105 hover:bg-accent hover:text-white
          `}
          href="https://www.franksbooklog.com/reviews/"
        >
          <span
            class={`
              relative inline-block pb-1
              after:absolute after:bottom-0 after:left-0 after:h-px after:w-full
              after:origin-center after:scale-x-0 after:transform-gpu
              after:bg-white after:transition-transform after:duration-500
              group-hover/all-reviews:after:scale-x-100
            `}
          >
            More Book Reviews
          </span>
        </a>
      </div>
    </nav>
  </div>
</div>
