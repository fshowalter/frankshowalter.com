---
import HeroLayout from "~/components/layout/HeroLayout.astro";

import Home from "./Home.astro";

const title = "Frank Showalter";
const description = "Mostly movie reviews, sometimes book reviews.";
---

<HeroLayout
  headProps={{
    canonical: true,
    meta: {
      description,
    },
    openGraph: {
      description,
      type: "website",
    },
    title,
  }}
  heroProps={{
    deck: (
      <>
        Mostly{" "}
        <a
          class="
            relative inline-block text-accent
            after:absolute after:bottom-0 after:left-0 after:h-px after:w-full
            after:origin-center after:scale-x-0 after:bg-accent
            after:transition-transform after:duration-500
            hover:after:scale-x-100
          "
          href="#movie-reviews"
        >
          movie reviews
        </a>
        , sometimes{" "}
        <a
          class="
            relative inline-block text-accent
            after:absolute after:bottom-0 after:left-0 after:h-px after:w-full
            after:origin-center after:scale-x-0 after:bg-accent
            after:transition-transform after:duration-500
            hover:after:scale-x-100
          "
          href="#book-reviews"
        >
          book reviews
        </a>
        .
      </>
    ),
    title,
  }}
  logo={false}
>
  <Home />
</HeroLayout>
